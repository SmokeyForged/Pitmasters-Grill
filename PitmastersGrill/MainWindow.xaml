<Window x:Class="PitmastersGrill.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PitmastersGrill"
        mc:Ignorable="d"
        Title="Pitmasters Grill"
        Height="430"
        Width="760"
        MinHeight="430"
        MinWidth="760"
        Background="{DynamicResource WindowBackgroundBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <local:ThreatCynoHullHighlightConverter x:Key="ThreatCynoHullHighlightConverter" />
        <local:LastShipMatchesCynoHullConverter x:Key="LastShipMatchesCynoHullConverter" />

        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#1F1F1F"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#252525"/>
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BodyTextBrush" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#DDDDDD"/>
        <SolidColorBrush x:Key="GridBackgroundBrush" Color="#2B2B2B"/>
        <SolidColorBrush x:Key="GridAlternateBrush" Color="#323232"/>
        <SolidColorBrush x:Key="GridHeaderBrush" Color="#202020"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#3A3A3A"/>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="RowBackground" Value="{DynamicResource GridBackgroundBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridAlternateBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource GridLineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource GridLineBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding BaitOverride}" Value="True">
                    <Setter Property="Background" Value="#D4A017"/>
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding LastPublicCynoCapableHull, Converter={StaticResource ThreatCynoHullHighlightConverter}}"
                             Value="True">
                    <Setter Property="Background" Value="#B45309"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>

                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource LastShipMatchesCynoHullConverter}">
                            <Binding Path="LastShipSeenName"/>
                            <Binding Path="LastPublicCynoCapableHull"/>
                            <Binding Path="KnownCynoOverride"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="#991B1B"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
        </Style>

        <Style x:Key="SettingsLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="CompactModeToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#606060"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Content" Value="Compact Mode"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Content" Value="Normal Mode"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                Padding="12"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=CompactModeToggleButton}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                Margin="0,0,20,0">
                        <TextBlock Text="Pitmasters Grill"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HeaderTextBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            x:Name="IntelUpdateBanner"
                            Background="#155724"
                            Padding="10,8"
                            Margin="0,0,20,0"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="IntelUpdateStatusText"
                                       HorizontalAlignment="Center"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       Text="KILLMAIL INTEL CURRENT"/>
                            <TextBlock x:Name="IntelUpdateDetailText"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0"
                                       Foreground="#F3F3F3"
                                       Text="Current through latest published archive"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Vertical"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,12,0">
                            <TextBlock x:Name="BoardPopulationStatusText"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="Board population idle"/>
                            <TextBlock x:Name="LastRefreshedText"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="Last Refreshed: --"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                x:Name="ClearBoardButton"
                                Padding="14,6"
                                MinWidth="90"
                                Content="Clear"
                                Click="ClearBoardButton_Click" Margin="0,0,0,26"/>
                    </Grid>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,12,0,0"
                        Padding="10,8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1">
                    <WrapPanel VerticalAlignment="Center">
                        <Border Width="14"
                                Height="14"
                                Background="#D4A017"
                                BorderBrush="#EAB308"
                                BorderThickness="1"
                                Margin="0,0,6,0"/>
                        <TextBlock Text="Yellow = Bait [B]"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,18,0"/>

                        <Border Width="14"
                                Height="14"
                                Background="#B45309"
                                BorderBrush="#D97706"
                                BorderThickness="1"
                                Margin="0,0,6,0"/>
                        <TextBlock Text="Orange = Possible Risk [!]"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,18,0"/>

                        <Border Width="14"
                                Height="14"
                                Background="#991B1B"
                                BorderBrush="#B91C1C"
                                BorderThickness="1"
                                Margin="0,0,6,0"/>
                        <TextBlock Text="Red = High Risk [!!]"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </WrapPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,6">
                <ToggleButton x:Name="CompactModeToggleButton"
                              Style="{StaticResource CompactModeToggleStyle}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"/>
            </Grid>

            <TabControl x:Name="MainTabControl"
                        Grid.Row="1"
                        Background="{DynamicResource WindowBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}">
                <TabItem Header="Board">
                    <Grid Background="{DynamicResource WindowBackgroundBrush}">
                        <Grid x:Name="BoardOverlayHost">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60*"/>
                                <ColumnDefinition Width="12*"/>
                                <ColumnDefinition Width="9*"/>
                                <ColumnDefinition Width="649*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid x:Name="PilotBoard"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      SelectionChanged="PilotBoard_SelectionChanged"
                                      MouseDoubleClick="PilotBoard_MouseDoubleClick" Grid.ColumnSpan="4">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Sig" Width="42">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value=""/>
                                                            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding BaitOverride}" Value="True">
                                                                    <Setter Property="Text" Value="B"/>
                                                                </DataTrigger>

                                                                <DataTrigger Binding="{Binding LastPublicCynoCapableHull, Converter={StaticResource ThreatCynoHullHighlightConverter}}"
                                                                             Value="True">
                                                                    <Setter Property="Text" Value="!"/>
                                                                </DataTrigger>

                                                                <DataTrigger Value="True">
                                                                    <DataTrigger.Binding>
                                                                        <MultiBinding Converter="{StaticResource LastShipMatchesCynoHullConverter}">
                                                                            <Binding Path="LastShipSeenName"/>
                                                                            <Binding Path="LastPublicCynoCapableHull"/>
                                                                            <Binding Path="KnownCynoOverride"/>
                                                                        </MultiBinding>
                                                                    </DataTrigger.Binding>
                                                                    <Setter Property="Text" Value="!!"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Character" Binding="{Binding CharacterName}" Width="2*"/>
                                    <DataGridTextColumn Header="Alliance" Binding="{Binding AllianceName}" Width="1.8*"/>
                                    <DataGridTextColumn Header="Corp" Binding="{Binding CorpName}" Width="1.8*"/>
                                    <DataGridTextColumn Header="Kills" Binding="{Binding KillCount}" Width="0.9*"/>
                                    <DataGridTextColumn Header="Losses" Binding="{Binding LossCount}" Width="0.9*"/>
                                    <DataGridTextColumn Header="Avg Fleet Size"
                                                        Binding="{Binding AvgAttackersWhenAttacking, StringFormat={}{0:0}}"
                                                        Width="1.2*"/>
                                    <DataGridTextColumn Header="Last Ship Seen" Binding="{Binding LastShipSeenName}" Width="1.8*"/>
                                    <DataGridTextColumn Header="Last Seen" Binding="{Binding LastShipSeenDateDisplay}" Width="1.2*"/>
                                    <DataGridTextColumn Header="Cyno Hull Seen" Binding="{Binding LastPublicCynoCapableHull}" Width="1.8*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border x:Name="DetailPane"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Width="300"
                                    Height="280"
                                    Margin="0,0,8,8"
                                    Padding="12"
                                    Background="#CC252525"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Panel.ZIndex="10" Grid.Column="3">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               x:Name="SelectedCharacterText"
                                               Text="Selected Character"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HeaderTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,12,0"/>

                                    <Button Grid.Row="0"
                                            Grid.Column="1"
                                            x:Name="CloseDetailsButton"
                                            Padding="12,4"
                                            Content="Close Details"
                                            Click="CloseDetailsButton_Click"/>

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               x:Name="FullCorpText"
                                               Margin="0,12,0,0"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Full Corp: --"/>

                                    <TextBlock Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               x:Name="FullAllianceText"
                                               Margin="0,8,0,0"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Full Alliance: --"/>

                                    <TextBlock Grid.Row="3"
                                               Grid.ColumnSpan="2"
                                               x:Name="FreshnessText"
                                               Margin="0,8,0,0"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Freshness: --"/>

                                    <Grid Grid.Row="4"
                                          Grid.ColumnSpan="2"
                                          Margin="0,12,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Foreground="{DynamicResource HeaderTextBrush}"
                                                   Text="Notes / Tags"/>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <CheckBox x:Name="BaitOverrideCheckBox"
                                                      VerticalAlignment="Center"
                                                      Foreground="{DynamicResource BodyTextBrush}"
                                                      Content="Bait"
                                                      Margin="0,0,10,0"
                                                      Checked="BaitOverrideCheckBox_Changed"
                                                      Unchecked="BaitOverrideCheckBox_Changed"/>
                                            <CheckBox x:Name="KnownCynoOverrideCheckBox"
                                                      VerticalAlignment="Center"
                                                      Foreground="{DynamicResource BodyTextBrush}"
                                                      Content="Known-Cyno Override"
                                                      Checked="KnownCynoOverrideCheckBox_Changed"
                                                      Unchecked="KnownCynoOverrideCheckBox_Changed"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="5"
                                          Grid.ColumnSpan="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBox Grid.Row="0"
                                                 x:Name="NotesTagsBox"
                                                 Margin="0,0,0,12"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 MinHeight="100"/>

                                        <Button Grid.Row="1"
                                                x:Name="OpenZkillButton"
                                                Padding="12,6"
                                                HorizontalAlignment="Right"
                                                Content="Open zKill"
                                                Click="OpenZkillButton_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="{DynamicResource WindowBackgroundBrush}">
                        <StackPanel Margin="16">
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Appearance"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HeaderTextBrush}"
                                               Margin="0,0,0,12"/>

                                    <CheckBox x:Name="DarkModeCheckBox"
                                              Content="Enable Dark Mode"
                                              Foreground="{DynamicResource BodyTextBrush}"
                                              Margin="0,0,0,10"
                                              Checked="DarkModeCheckBox_Changed"
                                              Unchecked="DarkModeCheckBox_Changed"/>

                                    <CheckBox x:Name="AlwaysOnTopCheckBox"
                                              Content="Always On Top"
                                              Foreground="{DynamicResource BodyTextBrush}"
                                              Margin="0,0,0,14"
                                              Checked="AlwaysOnTopCheckBox_Changed"
                                              Unchecked="AlwaysOnTopCheckBox_Changed"/>

                                    <TextBlock Text="Window Surface Opacity"
                                               Foreground="{DynamicResource BodyTextBrush}"
                                               Margin="0,0,0,6"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Slider Grid.Column="0"
                                                x:Name="WindowOpacitySlider"
                                                Minimum="35"
                                                Maximum="100"
                                                TickFrequency="5"
                                                IsSnapToTickEnabled="False"
                                                ValueChanged="WindowOpacitySlider_ValueChanged"/>

                                        <TextBlock Grid.Column="1"
                                                   x:Name="WindowOpacityValueText"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BodyTextBrush}"
                                                   Text="100%"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Version Information"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HeaderTextBrush}"
                                               Margin="0,0,0,12"/>

                                    <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                               Text="Technical Preview-v0.8.0"/>

                                    <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                               Margin="0,4,0,0"
                                               Text="SmokeyLabs"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Diagnostics"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HeaderTextBrush}"
                                               Margin="0,0,0,12"/>

                                    <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                               Text="Enable local killmail DB pull from a rolling 30-day seed window. The background updater will continue forward and keep the DB current while PMG remains usable."/>

                                    <WrapPanel Margin="0,4,0,0">
                                        <Button x:Name="EnableKillmailDbPullButton"
                                                Width="180"
                                                Padding="14,6"
                                                Margin="0,0,10,0"
                                                HorizontalAlignment="Left"
                                                Content="Enable KillMail DB Pull"
                                                Click="EnableKillmailDbPullButton_Click"/>

                                        <Button x:Name="OpenLogsButton"
                                                Width="120"
                                                Padding="14,6"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,10,0"
                                                Content="Logs"
                                                Click="OpenLogsButton_Click"/>
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                               Margin="0,10,0,0"
                                               Text="Open the PMG logs folder for startup, UI, clipboard, import, database, and error diagnostics."/>

                                    <Separator Margin="0,8,0,14"/>

                                    <TextBlock Text="Killmail Data Location"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HeaderTextBrush}"
                                               Margin="0,0,0,8"/>

                                    <TextBlock x:Name="KillmailDataPathModeText"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               Text="Using default LocalAppData path."/>

                                    <TextBlock x:Name="EffectiveKillmailDataPathText"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               TextWrapping="Wrap"
                                               Text="Effective path: --"/>

                                    <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                               Margin="0,6,0,4"
                                               Text="Set a custom killmail data root for Proton or non-standard storage layouts. Leave blank or click Use Default to return to PMG's default LocalAppData location."/>

                                    <TextBox x:Name="KillmailDataRootPathTextBox"
                                             Margin="0,0,0,10"
                                             MinWidth="420"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"/>

                                    <WrapPanel>
                                        <Button x:Name="SaveKillmailPathButton"
                                                Width="120"
                                                Padding="14,6"
                                                Margin="0,0,10,0"
                                                Content="Save Path"
                                                Click="SaveKillmailPathButton_Click"/>

                                        <Button x:Name="UseDefaultKillmailPathButton"
                                                Width="120"
                                                Padding="14,6"
                                                Margin="0,0,10,0"
                                                Content="Use Default"
                                                Click="UseDefaultKillmailPathButton_Click"/>
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                               Margin="0,10,0,0"
                                               Text="Restart PMG after changing the killmail data path. Path changes do not migrate existing killmail data automatically."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>