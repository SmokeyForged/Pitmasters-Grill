<Window x:Class="PitmastersGrill.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PitmastersGrill"
        xmlns:views="clr-namespace:PitmastersGrill.Views"
        mc:Ignorable="d"
        Title="Pitmasters Grill"
        Height="430"
        Width="760"
        MinHeight="300"
        MinWidth="420"
        Icon="Assets/PMGIcon.ico"
        Background="{DynamicResource WindowBackgroundBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <local:ThreatCynoHullHighlightConverter x:Key="ThreatCynoHullHighlightConverter" />
        <local:LastShipMatchesCynoHullConverter x:Key="LastShipMatchesCynoHullConverter" />

        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#1F1F1F"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#252525"/>
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BodyTextBrush" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#DDDDDD"/>
        <SolidColorBrush x:Key="GridBackgroundBrush" Color="#2B2B2B"/>
        <SolidColorBrush x:Key="GridAlternateBrush" Color="#323232"/>
        <SolidColorBrush x:Key="GridHeaderBrush" Color="#202020"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="AccentEmberBrush" Color="#F28C28"/>
        <SolidColorBrush x:Key="AccentHotCoalBrush" Color="#D94A1E"/>
        <SolidColorBrush x:Key="AccentAshBrush" Color="#858985"/>
        <SolidColorBrush x:Key="ThreatCriticalBrush" Color="#FF3B21"/>
        <SolidColorBrush x:Key="ThreatSevereBrush" Color="#D94A1E"/>
        <SolidColorBrush x:Key="ThreatHighBrush" Color="#F28C28"/>
        <SolidColorBrush x:Key="ThreatElevatedBrush" Color="#C79035"/>
        <SolidColorBrush x:Key="ThreatLowBrush" Color="#B6A36B"/>
        <SolidColorBrush x:Key="ThreatNeutralBrush" Color="#858985"/>
        <SolidColorBrush x:Key="SuccessGreenBrush" Color="#6FBF73"/>
        <SolidColorBrush x:Key="WarningAmberBrush" Color="#F6B94B"/>
        <SolidColorBrush x:Key="ErrorRedBrush" Color="#EF5350"/>
        <SolidColorBrush x:Key="BoardSignalConfirmedCovertBrush" Color="#B48CFF"/>
        <SolidColorBrush x:Key="BoardSignalConfirmedNormalBrush" Color="#EF5350"/>
        <SolidColorBrush x:Key="BoardSignalInferredCynoBrush" Color="#F28C28"/>
        <SolidColorBrush x:Key="BoardSignalPossibleBrush" Color="#F6B94B"/>
        <SolidColorBrush x:Key="BoardSignalBaitBrush" Color="#B8915E"/>

        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextTrimming" Value="None"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="RowBackground" Value="{DynamicResource GridBackgroundBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridAlternateBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource GridLineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource GridLineBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentEmberBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>

                <DataTrigger Binding="{Binding BoardSignalKind}" Value="Bait">
                    <Setter Property="Background" Value="{DynamicResource BoardSignalBaitBrush}"/>
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding BoardSignalKind}" Value="ConfirmedCovert">
                    <Setter Property="Background" Value="{DynamicResource BoardSignalConfirmedCovertBrush}"/>
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding BoardSignalKind}" Value="ConfirmedNormal">
                    <Setter Property="Background" Value="{DynamicResource BoardSignalConfirmedNormalBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding BoardSignalKind}" Value="InferredCyno">
                    <Setter Property="Background" Value="{DynamicResource BoardSignalInferredCynoBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding BoardSignalKind}" Value="Possible">
                    <Setter Property="Background" Value="{DynamicResource BoardSignalPossibleBrush}"/>
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextTrimming" Value="None"/>
        </Style>

        <Style x:Key="CompactModeToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="78"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#606060"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Content" Value="Compact"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Content" Value="Normal"/>
                </Trigger>
            </Style.Triggers>
        </Style>



        <Style x:Key="CompactActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="64"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#606060"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OpenDetailsActionButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactActionButtonStyle}">
            <Setter Property="Background" Value="#0891B2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#22D3EE"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>


    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                Padding="12"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="WindowDragHandle_MouseLeftButtonDown">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=CompactModeToggleButton}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                Margin="0,0,20,0">
                        <TextBlock Text="Pitmasters Grill"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HeaderTextBrush}"/>
                    </StackPanel>

                </Grid>

                <Border Grid.Row="1"
                        Margin="0,12,0,0"
                        Padding="8,5"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1">
                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Text="Sig:"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Margin="0,0,8,0"/>

                        <Border Width="12"
                                Height="12"
                                Background="{DynamicResource BoardSignalConfirmedCovertBrush}"
                                BorderBrush="{DynamicResource GridLineBrush}"
                                BorderThickness="1"
                                Margin="0,0,4,0"/>
                        <TextBlock Text="✦ confirmed covert"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Margin="0,0,10,0"/>

                        <Border Width="12"
                                Height="12"
                                Background="{DynamicResource BoardSignalConfirmedNormalBrush}"
                                BorderBrush="{DynamicResource GridLineBrush}"
                                BorderThickness="1"
                                Margin="0,0,4,0"/>
                        <TextBlock Text="◆ confirmed normal"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Margin="0,0,10,0"/>

                        <Border Width="12"
                                Height="12"
                                Background="{DynamicResource BoardSignalInferredCynoBrush}"
                                BorderBrush="{DynamicResource GridLineBrush}"
                                BorderThickness="1"
                                Margin="0,0,4,0"/>
                        <TextBlock Text="! inferred"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Margin="0,0,10,0"/>

                        <Border Width="12"
                                Height="12"
                                Background="{DynamicResource BoardSignalPossibleBrush}"
                                BorderBrush="{DynamicResource GridLineBrush}"
                                BorderThickness="1"
                                Margin="0,0,4,0"/>
                        <TextBlock Text="? possible"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Margin="0,0,10,0"/>

                        <Border Width="12"
                                Height="12"
                                Background="{DynamicResource BoardSignalBaitBrush}"
                                BorderBrush="{DynamicResource GridLineBrush}"
                                BorderThickness="1"
                                Margin="0,0,4,0"/>
                        <TextBlock Text="B bait"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="11"/>
                    </WrapPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        x:Name="CompactWindowDragHandle"
                        MinWidth="58"
                        Margin="0,0,8,0"
                        Padding="8,5"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        Cursor="SizeAll"
                        ToolTip="Drag to move PMG while Compact Mode is enabled."
                        MouseLeftButtonDown="WindowDragHandle_MouseLeftButtonDown">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=CompactModeToggleButton}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Move"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BodyTextBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="NoWrap"/>
                </Border>

                <Button Grid.Column="2"
                        x:Name="ClearBoardButton"
                        Style="{StaticResource CompactActionButtonStyle}"
                        Margin="0,0,8,0"
                        Content="Clear"
                        Click="ClearBoardButton_Click"/>

                <Button Grid.Column="3"
                        x:Name="OpenDetailsButton"
                        Style="{StaticResource OpenDetailsActionButtonStyle}"
                        Margin="0,0,8,0"
                        Content="Open Details"
                        IsEnabled="False"
                        Click="OpenDetailsButton_Click"/>

                <ToggleButton Grid.Column="4"
                              x:Name="CompactModeToggleButton"
                              Style="{StaticResource CompactModeToggleStyle}"
                              Margin="0,0,8,0"/>

                <Button Grid.Column="5"
                        x:Name="ExitApplicationButton"
                        Style="{StaticResource CompactActionButtonStyle}"
                        Content="Exit"
                        ToolTip="Exit PMG and stop PMG-owned background work."
                        Click="ExitApplicationButton_Click"/>
            </Grid>

            <TabControl x:Name="MainTabControl"
                        Grid.Row="1"
                        Background="{DynamicResource WindowBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}">
                <TabItem Header="Board">
                    <Grid Background="{DynamicResource WindowBackgroundBrush}">
                        <Grid x:Name="BoardOverlayHost">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60*"/>
                                <ColumnDefinition Width="12*"/>
                                <ColumnDefinition Width="9*"/>
                                <ColumnDefinition Width="649*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid x:Name="PilotBoard"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      SelectionChanged="PilotBoard_SelectionChanged"
                                      MouseDoubleClick="PilotBoard_MouseDoubleClick" Grid.ColumnSpan="4">
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn x:Name="SigColumn" Header="Sig" Width="42">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="Bold"
                                                           Text="{Binding BoardSignalIcon}"
                                                           ToolTip="{Binding BoardSignalToolTip}"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn x:Name="CharacterColumn" Header="Character" Binding="{Binding CharacterName}" Width="2*"/>
                                    <DataGridTextColumn x:Name="AllianceColumn" Header="Alliance" Binding="{Binding AllianceName}" Width="1.8*"/>
                                    <DataGridTextColumn x:Name="CorpColumn" Header="Corp" Binding="{Binding CorpName}" Width="1.8*"/>
                                    <DataGridTextColumn x:Name="KillsColumn" Header="Kills" Binding="{Binding KillCount}" Width="0.9*"/>
                                    <DataGridTextColumn x:Name="LossesColumn" Header="Losses" Binding="{Binding LossCount}" Width="0.9*"/>
                                    <DataGridTextColumn x:Name="AvgFleetSizeColumn"
                                                        Header="Avg Fleet Size"
                                                        Binding="{Binding AvgAttackersWhenAttacking, StringFormat={}{0:0}}"
                                                        Width="1.2*"/>
                                    <DataGridTextColumn x:Name="LastShipSeenColumn" Header="Last Ship Seen" Binding="{Binding LastShipSeenName}" Width="1.8*"/>
                                    <DataGridTextColumn x:Name="LastSeenColumn" Header="Last Seen" Binding="{Binding LastShipSeenDateDisplay}" Width="1.2*"/>
                                    <DataGridTextColumn x:Name="CynoHullSeenColumn" Header="Cyno Hull Seen" Binding="{Binding LastPublicCynoCapableHull}" Width="1.8*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border x:Name="DetailPane"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Width="300"
                                    Height="380"
                                    Margin="0,0,8,8"
                                    Padding="12"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Panel.ZIndex="10" Grid.Column="3">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               x:Name="SelectedCharacterText"
                                               Text="Selected Character"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HeaderTextBrush}"
                                               TextWrapping="Wrap"
                                               TextTrimming="None"
                                               Margin="0,0,12,0"/>

                                    <Button Grid.Row="0"
                                            Grid.Column="1"
                                            x:Name="CloseDetailsButton"
                                            Padding="12,4"
                                            Content="Close Details"
                                            Click="CloseDetailsButton_Click"/>

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               x:Name="FullCorpText"
                                               Margin="0,12,0,0"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Full Corp: --"/>

                                    <TextBlock Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               x:Name="FullAllianceText"
                                               Margin="0,8,0,0"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Full Alliance: --"/>

                                    <TextBlock Grid.Row="3"
                                               Grid.ColumnSpan="2"
                                               x:Name="FreshnessText"
                                               Margin="0,8,0,0"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Freshness: --"/>

                                    <TextBlock Grid.Row="4"
                                               Grid.ColumnSpan="2"
                                               x:Name="RecentPublicActivityText"
                                               Margin="0,8,0,0"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Recent Public Kill/Loss Activity: --"/>

                                    <TextBlock Grid.Row="5"
                                               Grid.ColumnSpan="2"
                                               x:Name="CynoSignalText"
                                               Margin="0,10,0,4"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentEmberBrush}"
                                               TextWrapping="Wrap"
                                               Text="Cyno Signal: Unknown"/>

                                    <ProgressBar Grid.Row="6"
                                                 Grid.ColumnSpan="2"
                                                 x:Name="CynoConfidenceBar"
                                                 Height="8"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="0"
                                                 Foreground="{DynamicResource AccentEmberBrush}"
                                                 Background="{DynamicResource SurfaceBrush}"
                                                 Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="7"
                                               Grid.ColumnSpan="2"
                                               x:Name="CynoEvidenceText"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Evidence: --"/>

                                    <TextBlock Grid.Row="8"
                                               Grid.ColumnSpan="2"
                                               x:Name="CynoLimitationsText"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Limitations: --"/>

                                    <TextBlock Grid.Row="9"
                                               Grid.ColumnSpan="2"
                                               x:Name="ExplainabilityText"
                                               Margin="0,8,0,0"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Sources / Freshness: --"/>

                                    <Grid Grid.Row="10"
                                          Grid.ColumnSpan="2"
                                          Margin="0,12,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Foreground="{DynamicResource HeaderTextBrush}"
                                                   Text="Notes / Tags"/>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <CheckBox x:Name="BaitOverrideCheckBox"
                                                      VerticalAlignment="Center"
                                                      Foreground="{DynamicResource BodyTextBrush}"
                                                      Content="Bait"
                                                      Margin="0,0,10,0"
                                                      Checked="BaitOverrideCheckBox_Changed"
                                                      Unchecked="BaitOverrideCheckBox_Changed"/>
                                            <CheckBox x:Name="KnownCynoOverrideCheckBox"
                                                      VerticalAlignment="Center"
                                                      Foreground="{DynamicResource BodyTextBrush}"
                                                      Content="Known-Cyno Override"
                                                      Checked="KnownCynoOverrideCheckBox_Changed"
                                                      Unchecked="KnownCynoOverrideCheckBox_Changed"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="11"
                                          Grid.ColumnSpan="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBox Grid.Row="0"
                                                 x:Name="NotesTagsBox"
                                                 Margin="0,0,0,12"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 MinHeight="100"/>

                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right">
                                            <Button x:Name="IgnoreAllianceButton"
                                                    Padding="12,6"
                                                    Margin="0,0,8,0"
                                                    Content="Ignore Alliance"
                                                    Click="IgnoreAllianceButton_Click"/>

                                            <Button x:Name="OpenZkillButton"
                                                    Padding="12,6"
                                                    Content="Open zKill"
                                                    Click="OpenZkillButton_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Settings">
                    <Grid Background="{DynamicResource WindowBackgroundBrush}">
                        <TabControl Margin="0,0,0,0"
                                    Background="{DynamicResource WindowBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}">
                            <TabItem Header="General">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Padding="12">
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Appearance"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource HeaderTextBrush}"
                                                       Margin="0,0,0,12"/>

                                            <CheckBox x:Name="DarkModeCheckBox"
                                                      Content="Enable Dark Mode"
                                                      Foreground="{DynamicResource BodyTextBrush}"
                                                      Margin="0,0,0,10"
                                                      Checked="DarkModeCheckBox_Changed"
                                                      Unchecked="DarkModeCheckBox_Changed"/>

                                            <TextBlock Text="PMG Theme"
                                                       Foreground="{DynamicResource BodyTextBrush}"
                                                       Margin="0,2,0,6"/>

                                            <ComboBox x:Name="VisualThemeComboBox"
                                                      Width="220"
                                                      HorizontalAlignment="Left"
                                                      Margin="0,0,0,10"
                                                      SelectionChanged="VisualThemeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Charcoal Ops"/>
                                                <ComboBoxItem Content="Tactical Grill"/>
                                                <ComboBoxItem Content="Classic PMG Grill"/>
                                            </ComboBox>

                                            <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="12"
                                                       Margin="0,0,0,12"
                                                       Text="Grill themes apply immediately while Dark Mode is enabled. Disable Dark Mode to use the legacy light palette."/>

                                            <CheckBox x:Name="AlwaysOnTopCheckBox"
                                                      Content="Always On Top"
                                                      Foreground="{DynamicResource BodyTextBrush}"
                                                      Margin="0,0,0,10"
                                                      Checked="AlwaysOnTopCheckBox_Changed"
                                                      Unchecked="AlwaysOnTopCheckBox_Changed"/>

                                            <CheckBox x:Name="PanelModeCheckBox"
                                                      Content="Enable Panel Mode on next launch"
                                                      Foreground="{DynamicResource BodyTextBrush}"
                                                      Margin="0,0,0,6"
                                                      Checked="PanelModeCheckBox_Changed"
                                                      Unchecked="PanelModeCheckBox_Changed"/>

                                            <TextBlock x:Name="PanelModeRestartNoticeText"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="12"
                                                       Margin="24,0,0,14"
                                                       Text="Panel Mode is disabled. Enable it to use the transparent overlay shell after restart."/>

                                            <TextBlock Text="Window Surface Opacity"
                                                       Foreground="{DynamicResource BodyTextBrush}"
                                                       Margin="0,0,0,6"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Slider Grid.Column="0"
                                                        x:Name="WindowOpacitySlider"
                                                        Minimum="35"
                                                        Maximum="100"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="WindowOpacitySlider_ValueChanged"/>

                                                <TextBlock Grid.Column="1"
                                                           x:Name="WindowOpacityValueText"
                                                           Margin="12,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource BodyTextBrush}"
                                                           Text="100%"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Accessibility">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Padding="12">
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Accessibility"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource HeaderTextBrush}"
                                                       Margin="0,0,0,12"/>

                                            <TextBlock Text="Color-Blind Signal Palette"
                                                       Foreground="{DynamicResource BodyTextBrush}"
                                                       Margin="0,0,0,6"/>

                                            <ComboBox x:Name="ColorBlindModeComboBox"
                                                      Width="260"
                                                      HorizontalAlignment="Left"
                                                      Margin="0,0,0,10"
                                                      SelectionChanged="ColorBlindModeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Off / Standard"/>
                                                <ComboBoxItem Content="Deuteranopia-friendly"/>
                                                <ComboBoxItem Content="Protanopia-friendly"/>
                                                <ComboBoxItem Content="Tritanopia-friendly"/>
                                                <ComboBoxItem Content="High-contrast safe"/>
                                            </ComboBox>

                                            <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                       Text="Color changes are paired with Sig icons and labels. Board text, grid lines, and details remain fully readable."/>
                                        </StackPanel>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Board Columns">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Padding="12">
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Board Column Visibility"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource HeaderTextBrush}"
                                                       Margin="0,0,0,12"/>

                                            <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                       Text="Choose which optional board columns are visible. The Character column always stays visible so rows remain identifiable."/>

                                            <WrapPanel Margin="0,8,0,12">
                                                <CheckBox x:Name="ShowSigColumnCheckBox"
                                                          Content="Sig"
                                                          Foreground="{DynamicResource BodyTextBrush}"
                                                          Margin="0,0,18,8"
                                                          Checked="BoardColumnVisibilityCheckBox_Changed"
                                                          Unchecked="BoardColumnVisibilityCheckBox_Changed"/>

                                                <CheckBox x:Name="ShowAllianceColumnCheckBox"
                                                          Content="Alliance"
                                                          Foreground="{DynamicResource BodyTextBrush}"
                                                          Margin="0,0,18,8"
                                                          Checked="BoardColumnVisibilityCheckBox_Changed"
                                                          Unchecked="BoardColumnVisibilityCheckBox_Changed"/>

                                                <CheckBox x:Name="ShowCorpColumnCheckBox"
                                                          Content="Corp"
                                                          Foreground="{DynamicResource BodyTextBrush}"
                                                          Margin="0,0,18,8"
                                                          Checked="BoardColumnVisibilityCheckBox_Changed"
                                                          Unchecked="BoardColumnVisibilityCheckBox_Changed"/>

                                                <CheckBox x:Name="ShowKillsColumnCheckBox"
                                                          Content="Kills"
                                                          Foreground="{DynamicResource BodyTextBrush}"
                                                          Margin="0,0,18,8"
                                                          Checked="BoardColumnVisibilityCheckBox_Changed"
                                                          Unchecked="BoardColumnVisibilityCheckBox_Changed"/>

                                                <CheckBox x:Name="ShowLossesColumnCheckBox"
                                                          Content="Losses"
                                                          Foreground="{DynamicResource BodyTextBrush}"
                                                          Margin="0,0,18,8"
                                                          Checked="BoardColumnVisibilityCheckBox_Changed"
                                                          Unchecked="BoardColumnVisibilityCheckBox_Changed"/>

                                                <CheckBox x:Name="ShowAvgFleetSizeColumnCheckBox"
                                                          Content="Avg Fleet Size"
                                                          Foreground="{DynamicResource BodyTextBrush}"
                                                          Margin="0,0,18,8"
                                                          Checked="BoardColumnVisibilityCheckBox_Changed"
                                                          Unchecked="BoardColumnVisibilityCheckBox_Changed"/>

                                                <CheckBox x:Name="ShowLastShipSeenColumnCheckBox"
                                                          Content="Last Ship Seen"
                                                          Foreground="{DynamicResource BodyTextBrush}"
                                                          Margin="0,0,18,8"
                                                          Checked="BoardColumnVisibilityCheckBox_Changed"
                                                          Unchecked="BoardColumnVisibilityCheckBox_Changed"/>

                                                <CheckBox x:Name="ShowLastSeenColumnCheckBox"
                                                          Content="Last Seen"
                                                          Foreground="{DynamicResource BodyTextBrush}"
                                                          Margin="0,0,18,8"
                                                          Checked="BoardColumnVisibilityCheckBox_Changed"
                                                          Unchecked="BoardColumnVisibilityCheckBox_Changed"/>

                                                <CheckBox x:Name="ShowCynoHullSeenColumnCheckBox"
                                                          Content="Cyno Hull Seen"
                                                          Foreground="{DynamicResource BodyTextBrush}"
                                                          Margin="0,0,18,8"
                                                          Checked="BoardColumnVisibilityCheckBox_Changed"
                                                          Unchecked="BoardColumnVisibilityCheckBox_Changed"/>
                                            </WrapPanel>

                                            <WrapPanel>
                                                <Button x:Name="ShowAllBoardColumnsButton"
                                                        Width="140"
                                                        Padding="14,6"
                                                        Margin="0,0,10,0"
                                                        Content="Show All"
                                                        Click="ShowAllBoardColumnsButton_Click"/>

                                                <Button x:Name="ResetBoardColumnsButton"
                                                        Width="140"
                                                        Padding="14,6"
                                                        Margin="0,0,10,0"
                                                        Content="Reset Defaults"
                                                        Click="ResetBoardColumnsButton_Click"/>
                                            </WrapPanel>

                                            <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                       Margin="0,10,0,0"
                                                       Text="Column choices are saved immediately and reused on the next PMG launch."/>
                                        </StackPanel>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Version">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Padding="12">
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Version Information"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource HeaderTextBrush}"
                                                       Margin="0,0,0,12"/>

                                            <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                       Text="Technical Preview-v0.9.4"/>

                                            <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                       Margin="0,4,0,0"
                                                       Text="SmokeyLabs"/>

                                            <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                       Margin="0,12,0,0">
                                                <Run Text="For more information, visit the GitHub repo: "/>
                                                <Hyperlink NavigateUri="https://github.com/SmokeyForged/Pitmasters-Grill"
                                                           RequestNavigate="GitHubRepoLink_RequestNavigate">
                                                    <Run Text="https://github.com/SmokeyForged/Pitmasters-Grill"/>
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Diagnostics">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Padding="12">
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Diagnostics"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource HeaderTextBrush}"
                                                       Margin="0,0,0,12"/>

                                            <WrapPanel Margin="0,4,0,0">
                                                <Button x:Name="OpenLogsButton"
                                                        Width="120"
                                                        Padding="14,6"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,0,10,8"
                                                        Content="Logs"
                                                        Click="OpenLogsButton_Click"/>

                                                <Button x:Name="PackageDiagnosticsButton"
                                                        Width="160"
                                                        Padding="14,6"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,0,10,8"
                                                        Content="Export Diagnostics Package"
                                                        Click="PackageDiagnosticsButton_Click"/>

                                                <Button x:Name="OpenDiagnosticsFolderButton"
                                                        Width="160"
                                                        Padding="14,6"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,0,10,8"
                                                        Content="Diagnostics Folder"
                                                        Click="OpenDiagnosticsFolderButton_Click"/>

                                                <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,8"
                                                           Text="Log Level"/>

                                                <ComboBox x:Name="LogLevelComboBox"
                                                          Width="140"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,0,8"
                                                          SelectionChanged="LogLevelComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="Normal"/>
                                                    <ComboBoxItem Content="Debug"/>
                                                </ComboBox>
                                            </WrapPanel>

                                            <TextBlock x:Name="DiagnosticsStatusText"
                                                       Style="{StaticResource SettingsLabelStyle}"
                                                       Margin="0,6,0,0"
                                                       Text="Diagnostics ready."/>

                                            <TextBlock Text="Provider Health"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource HeaderTextBrush}"
                                                       Margin="0,14,0,8"/>

                                            <WrapPanel Margin="0,0,0,8">
                                                <Button x:Name="RefreshProviderHealthButton"
                                                        Width="150"
                                                        Padding="14,6"
                                                        Margin="0,0,10,0"
                                                        Content="Refresh Providers"
                                                        Click="RefreshProviderHealthButton_Click"/>
                                            </WrapPanel>

                                            <DataGrid x:Name="ProviderHealthGrid"
                                                      AutoGenerateColumns="False"
                                                      IsReadOnly="True"
                                                      Height="150"
                                                      Margin="0,0,0,12">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Provider" Binding="{Binding ProviderName}" Width="1.4*"/>
                                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.9*"/>
                                                    <DataGridTextColumn Header="Last Success" Binding="{Binding LastSuccessUtc}" Width="1.2*"/>
                                                    <DataGridTextColumn Header="Last Failure" Binding="{Binding LastFailureUtc}" Width="1.2*"/>
                                                    <DataGridTextColumn Header="Failures" Binding="{Binding RecentFailureCount}" Width="0.7*"/>
                                                    <DataGridTextColumn Header="Avg ms" Binding="{Binding AverageLatencyMs, StringFormat={}{0:0}}" Width="0.7*"/>
                                                    <DataGridTextColumn Header="Cache H/M" Binding="{Binding CacheHitMissDisplay}" Width="0.8*"/>
                                                    <DataGridTextColumn Header="Last Error" Binding="{Binding LastErrorSummary}" Width="2*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock Text="Cache Maintenance"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource HeaderTextBrush}"
                                                       Margin="0,2,0,8"/>

                                            <WrapPanel Margin="0,0,0,8">
                                                <Button x:Name="RefreshCacheStatsButton"
                                                        Width="150"
                                                        Padding="14,6"
                                                        Margin="0,0,10,8"
                                                        Content="Refresh Cache Stats"
                                                        Click="RefreshCacheStatsButton_Click"/>
                                                <Button x:Name="ClearExpiredCacheButton"
                                                        Width="150"
                                                        Padding="14,6"
                                                        Margin="0,0,10,8"
                                                        Content="Clear Expired"
                                                        Click="ClearExpiredCacheButton_Click"/>
                                                <Button x:Name="VacuumCacheButton"
                                                        Width="150"
                                                        Padding="14,6"
                                                        Margin="0,0,10,8"
                                                        Content="Compact / Vacuum"
                                                        Click="VacuumCacheButton_Click"/>
                                                <Button x:Name="ClearAllCacheButton"
                                                        Width="150"
                                                        Padding="14,6"
                                                        Margin="0,0,10,8"
                                                        Content="Clear All Cache"
                                                        Click="ClearAllCacheButton_Click"/>
                                                <Button x:Name="RebuildKillmailDerivedIntelButton"
                                                        Width="210"
                                                        Padding="14,6"
                                                        Margin="0,0,10,8"
                                                        Content="Rebuild Killmail Derived Intel"
                                                        Click="RebuildKillmailDerivedIntelButton_Click"/>
                                            </WrapPanel>

                                            <TextBlock x:Name="CacheStatsText"
                                                       Style="{StaticResource SettingsLabelStyle}"
                                                       FontFamily="Consolas"
                                                       TextWrapping="Wrap"
                                                       Text="Cache stats not loaded."/>

                                            <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                       Margin="0,10,0,0"
                                                       Text="Open logs for startup, UI, clipboard, import, database, and error diagnostics. Package Diagnostics creates a ZIP suitable for troubleshooting."/>

                                            <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                       Margin="0,6,0,0"
                                                       Text="Diagnostic packages include summaries, provider health, cache stats, active PMG logs, and debug traces. Raw clipboard contents and full cache database contents are not collected."/>

                                            <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                       Margin="0,6,0,0"
                                                       Text="Use Debug only while investigating freezes or ingest issues. Normal keeps log volume lower."/>
                                        </StackPanel>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>

                        </TabControl>
                    </Grid>
                </TabItem>
                <TabItem Header="Ignore List">
                    <views:IgnoreAllianceListView x:Name="IgnoreAllianceListViewControl"/>
                </TabItem>
                <TabItem Header="Intel">
                    <TabControl Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}">
                        <TabItem Header="Status">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Padding="12"
                                          Background="{DynamicResource WindowBackgroundBrush}">
                                <Border x:Name="IntelUpdateBanner"
                                        Background="#155724"
                                        Padding="12,8"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock x:Name="IntelUpdateStatusText"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Text="Intel current"/>
                                        <TextBlock x:Name="IntelUpdateDetailText"
                                                   Foreground="#F3F3F3"
                                                   FontSize="12"
                                                   Text="Through latest archive"/>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Config">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Padding="12">
                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Killmail Intel Configuration"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource HeaderTextBrush}"
                                                   Margin="0,0,0,12"/>

                                        <TextBlock Text="Max Killmail Age (days)"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource HeaderTextBrush}"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock x:Name="EffectiveMaxKillmailAgeText"
                                                   Style="{StaticResource SettingsLabelStyle}"
                                                   Text="Effective max killmail age: 30 days"/>

                                        <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                   Margin="0,6,0,4"
                                                   Text="Controls the seed window used when you run Enable KillMail DB Pull. Changes apply the next time you trigger a fresh bootstrap."/>

                                        <TextBox x:Name="MaxKillmailAgeDaysTextBox"
                                                 Margin="0,0,0,10"
                                                 Width="140"
                                                 HorizontalAlignment="Left"/>

                                        <WrapPanel Margin="0,0,0,12">
                                            <Button x:Name="SaveMaxKillmailAgeButton"
                                                    Width="120"
                                                    Padding="14,6"
                                                    Margin="0,0,10,0"
                                                    Content="Save Age"
                                                    Click="SaveMaxKillmailAgeButton_Click"/>

                                            <Button x:Name="UseDefaultMaxKillmailAgeButton"
                                                    Width="120"
                                                    Padding="14,6"
                                                    Margin="0,0,10,0"
                                                    Content="Use Default"
                                                    Click="UseDefaultMaxKillmailAgeButton_Click"/>
                                        </WrapPanel>

                                        <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                   Text="Enable local killmail DB pull from the configured max-age seed window. The background updater will continue forward and keep the DB current while PMG remains usable."/>

                                        <WrapPanel Margin="0,4,0,14">
                                            <Button x:Name="EnableKillmailDbPullButton"
                                                    Width="180"
                                                    Padding="14,6"
                                                    Margin="0,0,10,0"
                                                    HorizontalAlignment="Left"
                                                    Content="Enable KillMail DB Pull"
                                                    Click="EnableKillmailDbPullButton_Click"/>
                                        </WrapPanel>

                                        <TextBlock Text="Killmail Data Location"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource HeaderTextBrush}"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock x:Name="KillmailDataPathModeText"
                                                   Style="{StaticResource SettingsLabelStyle}"
                                                   Text="Using default LocalAppData path."/>

                                        <TextBlock x:Name="EffectiveKillmailDataPathText"
                                                   Style="{StaticResource SettingsLabelStyle}"
                                                   TextWrapping="Wrap"
                                                   Text="Effective path: --"/>

                                        <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                   Margin="0,6,0,4"
                                                   Text="Set a custom killmail data root for Proton or non-standard storage layouts. Leave blank or click Use Default to return to PMG's default LocalAppData location."/>

                                        <TextBox x:Name="KillmailDataRootPathTextBox"
                                                 Margin="0,0,0,10"
                                                 MinWidth="220"
                                                 HorizontalAlignment="Stretch"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>

                                        <WrapPanel>
                                            <Button x:Name="SaveKillmailPathButton"
                                                    Width="120"
                                                    Padding="14,6"
                                                    Margin="0,0,10,0"
                                                    Content="Save Path"
                                                    Click="SaveKillmailPathButton_Click"/>

                                            <Button x:Name="UseDefaultKillmailPathButton"
                                                    Width="120"
                                                    Padding="14,6"
                                                    Margin="0,0,10,0"
                                                    Content="Use Default"
                                                    Click="UseDefaultKillmailPathButton_Click"/>
                                        </WrapPanel>

                                        <TextBlock Style="{StaticResource SettingsLabelStyle}"
                                                   Margin="0,10,0,0"
                                                   Text="Restart PMG after changing the killmail data path. Path changes do not migrate existing killmail data automatically."/>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </TabItem>
            </TabControl>

            <Border Grid.Row="2"
                    Margin="0,6,0,0"
                    Padding="8,5"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="BoardPopulationStatusText"
                               Grid.Column="0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="Board population idle"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <TextBlock x:Name="LastRefreshedText"
                               Grid.Column="1"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="Last Refreshed: --"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
