<Window x:Class="PitmastersGrill.Views.PilotDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PMG Details"
        Width="540"
        Height="661"
        MinWidth="460"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <TextBlock x:Name="PilotNameText"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HeaderTextBrush}"
                           Margin="0,0,0,6"/>

                <WrapPanel Margin="0,0,0,12">
                    <CheckBox x:Name="KnownCynoOverrideCheckBox"
                              Content="Known-Cyno Override"
                              Foreground="{DynamicResource BodyTextBrush}"
                              Margin="0,0,12,6"/>
                    <CheckBox x:Name="BaitOverrideCheckBox"
                              Content="Bait"
                              Foreground="{DynamicResource BodyTextBrush}"
                              Margin="0,0,12,6"/>
                </WrapPanel>

                <TextBlock Text="Pilot"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentEmberBrush}"/>
                <TextBlock x:Name="PilotSummaryText"
                           Foreground="{DynamicResource BodyTextBrush}"
                           Margin="0,2,0,10"/>

                <TextBlock Text="Recent Public Kill/Loss"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentEmberBrush}"/>
                <TextBlock x:Name="RecentActivityText"
                           Foreground="{DynamicResource BodyTextBrush}"
                           Margin="0,2,0,10"/>

                <TextBlock Text="Cyno Signal"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentEmberBrush}"/>
                <TextBlock x:Name="CynoSignalText"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentAshBrush}"
                           Margin="0,2,0,4"/>
                <ProgressBar x:Name="CynoConfidenceBar"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Foreground="{DynamicResource AccentAshBrush}"
                             Background="{DynamicResource SurfaceBrush}"
                             Margin="0,0,0,8"/>

                <TextBlock Text="Evidence"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentEmberBrush}"/>
                <TextBlock x:Name="EvidenceText"
                           Foreground="{DynamicResource BodyTextBrush}"
                           Margin="0,2,0,10"/>

                <TextBlock Text="Limitations"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentEmberBrush}"/>
                <TextBlock x:Name="LimitationsText"
                           Foreground="{DynamicResource BodyTextBrush}"
                           Margin="0,2,0,10"/>

                <TextBlock Text="Notes / Tags"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentEmberBrush}"/>
                <TextBox x:Name="NotesTagsBox"
                         Height="72"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,4,0,8"/>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1"
              Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <WrapPanel Grid.Row="0"
                       HorizontalAlignment="Right">
                <Button x:Name="IgnorePilotButton"
                        Padding="12,6"
                        Margin="0,0,8,0"
                        Content="Ignore Pilot"
                        Click="IgnorePilotButton_Click"/>
                <Button x:Name="IgnoreCorpButton"
                        Padding="12,6"
                        Margin="0,0,8,0"
                        Content="Ignore Corp"
                        Click="IgnoreCorpButton_Click"/>
                <Button x:Name="IgnoreAllianceButton"
                        Padding="12,6"
                        Margin="0,0,8,0"
                        Content="Ignore Alliance"
                        Click="IgnoreAllianceButton_Click"/>
                <Button Padding="12,6"
                        Margin="0,0,8,0"
                        Content="Open zKill"
                        Click="OpenZkillButton_Click"/>
                <Button Padding="12,6"
                        Content="Close"
                        Click="CloseButton_Click"/>
            </WrapPanel>

            <TextBlock Grid.Row="1"
                       x:Name="BottomFreshnessText"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MutedTextBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"/>
        </Grid>
    </Grid>
</Window>
