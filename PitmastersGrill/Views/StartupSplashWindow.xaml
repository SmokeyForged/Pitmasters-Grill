<Window x:Class="PitmastersGrill.Views.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pitmasters Grill"
        Width="560"
        Height="260"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        Topmost="True"
        Icon="../Assets/PMGIcon.ico"
        Background="#111111">
    <Border Padding="24" Background="#111111">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Pitmasters Grill"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White" />

            <TextBlock Grid.Row="2"
                       x:Name="StatusTextBlock"
                       Text="Checking local killmail database"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="White"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="4"
                       x:Name="DetailTextBlock"
                       Text="Preparing startup update state."
                       FontSize="13"
                       Foreground="#D0D0D0"
                       TextWrapping="Wrap" />

            <ProgressBar Grid.Row="6"
                         x:Name="ProgressBarControl"
                         Height="18"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         IsIndeterminate="False" />

            <TextBlock Grid.Row="7"
                       x:Name="ExceptionTextBlock"
                       Margin="0,14,0,0"
                       Text="The database is out of date, please standby while we refresh local intel."
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#FFCC66"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />
        </Grid>
    </Border>
</Window>
